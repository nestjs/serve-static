{
  "name": "@nestjs/serve-static",
  "version": "5.0.5",
  "description": "Nest - modern, fast, powerful node.js web framework (@serve-static)",
  "author": "Kamil Mysliwiec",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "tsc -p tsconfig.json",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "oxlint lib/ --fix",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "prepublish:next": "npm run build",
    "publish:next": "npm publish --access public --tag next",
    "prerelease": "npm run build",
    "release": "release-it",
    "test:e2e": "vitest run",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@fastify/static": "^8.0.4 || ^9.0.0",
    "@nestjs/common": "^11.0.2",
    "@nestjs/core": "^11.0.2",
    "express": "^5.0.1",
    "fastify": "^5.2.1"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "@fastify/static": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-angular": "21.1.0",
    "@fastify/static": "9.1.3",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@nestjs/testing": "11.1.27",
    "@types/node": "24.13.2",
    "@types/supertest": "7.2.0",
    "express": "5.2.1",
    "fastify": "5.8.5",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxlint": "^1.60.0",
    "prettier": "3.9.1",
    "reflect-metadata": "0.2.2",
    "release-it": "20.2.1",
    "rxjs": "7.8.2",
    "supertest": "7.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs/serve-static"
  },
  "dependencies": {
    "path-to-regexp": "8.4.2"
  }
}
